<section class="events-grid">
    {% for post in eventslist %}
        <article class="event-card {% if post.data.featured %}event-card--featured{% endif %}">
            <a href="{{ post.url | url }}" class="event-card__link">
                {% if post.data.image %}
                    <div class="event-card__media">
                        <img src="{{ post.data.image | url }}" alt="{{ post.data.title }}" loading="lazy">
                        {% if post.data.featured %}
                            <span class="event-card__badge">Featured</span>
                        {% endif %}
                    </div>
                {% endif %}

                <div class="event-card__body">
                    <time class="event-card__date">
                        {{ post.data.date | readableDate }}
                        {% if post.data.endDate %}
                            &ndash; {{ post.data.endDate | readableDate }}
                        {% endif %}
                    </time>

                    <h3 class="event-card__title">
                        {{ post.data.title or "Untitled" }}
                    </h3>

                    {% if post.data.description %}
                        <p class="event-card__desc">{{ post.data.description }}</p>
                    {% endif %}

                    {% if post.data.tags %}
                        <ul class="event-card__tags">
                            {% for tag in post.data.tags %}
                                {% if tag != "event" %}
                                    <li>{{ tag }}</li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </a>
        </article>
    {% endfor %}
</section>

<style>
.events-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
  margin: 1.5rem 0;
}

.event-card {
  border: 1px solid #e2e2e2;
  border-radius: 8px;
  overflow: hidden;
  transition: box-shadow 0.15s ease, transform 0.15s ease;
}

.event-card:hover {
  box-shadow: 0 4px 14px rgba(21, 224, 174, 0.08);
  transform: translateY(-2px);
}

.event-card__link {
  display: block;
  color: inherit;
  text-decoration: none;
}

.event-card__media {
  position: relative;
  aspect-ratio: 16 / 9;
  background: #f3f3f3;
}

.event-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.event-card__badge {
  position: absolute;
  top: 8px;
  left: 8px;
  background: #09a1a1;
  color: #fff;
  font-size: 0.75rem;
  padding: 2px 8px;
  border-radius: 4px;
}

.event-card--featured {
  border-color: #155242;
  border-width: 2px;
}

.event-card__body {
  padding: 1rem;
}

.event-card__date {
  font-size: 0.8rem;
  color: #666;
}

.event-card__title {
  margin: 0.25rem 0;
}

.event-card__desc {
  font-size: 0.9rem;
  color: #444;
}

.event-card__tags {
  display: flex;
  gap: 6px;
  list-style: none;
  padding: 0;
  margin-top: 0.5rem;
  flex-wrap: wrap;
}

.event-card__tags li {
  font-size: 0.7rem;
  background: #f0f0f0;
  padding: 2px 8px;
  border-radius: 12px;
  text-transform: capitalize;
}
</style>
