<div class="projects-publications">
  <div class="projects-publications__col">
    <h3>Projects</h3>
    <ul class="pp-list">
      {% for project in projects %}
        <li class="pp-item">
          {% if project.image %}
            <div class="pp-item__media">
              <img src="{{ project.image | url }}" alt="{{ project.title }}" loading="lazy">
            </div>
          {% endif %}
          <div class="pp-item__body">
            <a href="{{ project.url | url }}" class="pp-item__title">{{ project.title }}</a>
            {% if project.status %}
              <span class="pp-item__badge">{{ project.status }}</span>
            {% endif %}
            <p class="pp-item__desc">{{ project.description }}</p>
            {% if project.repo %}
              <a href="{{ project.repo }}" class="pp-item__repo" target="_blank" rel="noopener">View on GitHub →</a>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>

  <div class="projects-publications__col">
    <h3>Publications</h3>
    <ul class="pp-list">
      {% for pub in publications | sort(true, true, "date") %}
        <li class="pp-item">
          {% if pub.image %}
            <div class="pp-item__media">
              <img src="{{ pub.image | url }}" alt="{{ pub.title }}" loading="lazy">
            </div>
          {% endif %}
          <div class="pp-item__body">
            <a href="{{ pub.url | url }}" class="pp-item__title">{{ pub.title }}</a>
            <p class="pp-item__meta">{{ pub.authors }} &middot; {{ pub.date }}</p>
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

<style>
.projects-publications {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin: 1.5rem 0;
}

.projects-publications__col h3 {
  margin-bottom: 0.75rem;
}

.pp-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.pp-item {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 1rem;
  align-items: flex-start;
  border: 1px solid #c9c9c9;
  border-radius: 8px;
  padding: 0.75rem 1rem;
  margin-bottom: 0.75rem;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  transition: box-shadow 0.15s ease, transform 0.15s ease;
}

.pp-item:hover {
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
  transform: translateY(-2px);
}

.pp-item__media {
  flex: 0 0 120px;
  flex-shrink: 0;
  width: 120px;
  aspect-ratio: 1 / 1;
  border-radius: 6px;
  overflow: hidden;
  background: #f3f3f3;
}

.pp-item__media img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  background: #fff
}

.pp-item__body {
  flex: 1;
  min-width: 0;
}

.pp-item__title {
  font-weight: 600;
  text-decoration: none;
  color: inherit;
}

.pp-item__badge {
  display: inline-block;
  font-size: 0.7rem;
  text-transform: uppercase;
  background: #eaf3de;
  color: #3b6d11;
  padding: 2px 8px;
  border-radius: 12px;
  margin-left: 8px;
}

.pp-item__desc {
  font-size: 0.85rem;
  color: #555;
  margin: 0.4rem 0;
}

.pp-item__meta {
  font-size: 0.8rem;
  color: #777;
  margin: 0.3rem 0 0;
}

.pp-item__repo {
  font-size: 0.8rem;
  color: #185fa5;
  text-decoration: none;
}

@media (max-width: 700px) {
  .projects-publications {
    grid-template-columns: 1fr;
  }

  .pp-item {
    flex-direction: column;
  }

  .pp-item__media {
    width: 100%;
    flex: none;
  }
}
</style>
