<section class="posts-grid">
  {% for post in postslist %}
    {% if not post.data.hide and not (skipFirst and loop.index0 == 0) %}
      <article class="post-card">
        <a href="{{ post.url | url }}" class="post-card__link">
          {% if post.data.image %}
            <div class="post-card__media">
              <img src="{{ post.data.image | url }}" alt="{{ post.data.title }}" loading="lazy">
            </div>
          {% endif %}

          <div class="post-card__body">
            <time class="post-card__date">{{ post.data.date | readableDate }}</time>
            <span class="post-card__author">by {{ post.data.author }}</span>

            <h3 class="post-card__title">
              {{ post.data.title or "Untitled" }}
            </h3>

            {% if post.data.summary %}
              <p class="post-card__summary">{{ post.data.summary }}</p>
            {% endif %}

            {% if post.data.tags %}
              <ul class="post-card__tags">
                {% for tag in post.data.tags %}
                  {% if tag != 'post' %}
                    <li>{{ tag }}</li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </a>
      </article>
    {% endif %}
  {% endfor %}
</section>

<style>
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.5rem;
  margin: 1.5rem 0;
}

.post-card {
  border: 1px solid #e2e2e2;
  border-radius: 8px;
  overflow: hidden;
  transition: box-shadow 0.15s ease, transform 0.15s ease;
}

.post-card:hover {
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

.post-card__link {
  display: block;
  color: inherit;
  text-decoration: none;
}

.post-card__media {
  aspect-ratio: 16 / 9;
  background: #f3f3f3;
}

.post-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.post-card__body {
  padding: 1rem;
}

.post-card__date,
.post-card__author {
  font-size: 0.78rem;
  color: #777;
}

.post-card__title {
  margin: 0.35rem 0;
  font-size: 1.05rem;
}

.post-card__summary {
  font-size: 0.88rem;
  color: #555;
}

.post-card__tags {
  display: flex;
  gap: 6px;
  list-style: none;
  padding: 0;
  margin-top: 0.5rem;
  flex-wrap: wrap;
}

.post-card__tags li {
  font-size: 0.7rem;
  background: #f0f0f0;
  padding: 2px 8px;
  border-radius: 12px;
  text-transform: capitalize;
}
</style>
